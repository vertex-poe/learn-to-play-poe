# This file is regenerated by poe-info-service on every write (e.g. a client's
# config.set call). Field comments below are regenerated too — any comments you
# add yourself will be removed the next time this file is saved. Values you set
# are preserved.

# Address to bind the WebSocket server to.
bind = '127.0.0.1'
# TCP port to listen on.
port = 47652
# Enable verbose debug logging.
debug_logging = false
# PoE install directories to ingest Client.txt from.
install_dirs = ['C:\Games\Path of Exile']
# Automatically add an install directory when a matching game process is seen running.
auto_detect_install_dir = true
# Executable basenames to look for when auto-detecting an install directory.
executable_names = ['PathOfExile_x64Steam.exe', 'PathOfExileSteam.exe', 'PathOfExile_x64.exe', 'PathOfExile.exe', 'PathOfExile_x64', 'PathOfExile']
